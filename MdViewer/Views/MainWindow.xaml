<Window x:Class="MdViewer.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:prism="http://prismlibrary.com/"
        prism:ViewModelLocator.AutoWireViewModel="True"
        Title="{Binding Title}" Height="720" Width="1100"
        MinHeight="560" MinWidth="860"
        Background="{DynamicResource AppBackgroundBrush}"
        FontFamily="Segoe UI, Microsoft YaHei UI"
        WindowStartupLocation="CenterScreen">
    <DockPanel LastChildFill="True">
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrushSoft}"
                BorderThickness="0,0,0,1"
                Padding="14,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="打开" Command="{Binding OpenFileCommand}" Margin="0,0,8,0" MinWidth="66"/>
                    <Button Content="收藏" Command="{Binding ToggleFavoriteCommand}" Margin="0,0,8,0" MinWidth="66"/>
                    <Button x:Name="ThemeMenuButton"
                            Content="{Binding ThemeButtonText}"
                            Click="OpenButtonContextMenu"
                            Margin="0,0,8,0"
                            MinWidth="96">
                        <Button.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="浅色"
                                          Command="{Binding UseLightThemeCommand}"
                                          IsCheckable="True"
                                          IsChecked="{Binding IsLightThemeSelected, Mode=OneWay}"/>
                                <MenuItem Header="深色"
                                          Command="{Binding UseDarkThemeCommand}"
                                          IsCheckable="True"
                                          IsChecked="{Binding IsDarkThemeSelected, Mode=OneWay}"/>
                                <MenuItem Header="跟随系统"
                                          Command="{Binding UseSystemThemeCommand}"
                                          IsCheckable="True"
                                          IsChecked="{Binding IsSystemThemeSelected, Mode=OneWay}"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                    <Button x:Name="ReadingMenuButton"
                            Content="阅读"
                            Click="OpenButtonContextMenu"
                            MinWidth="72">
                        <Button.ContextMenu>
                            <ContextMenu MinWidth="248" Padding="10">
                                <Grid Margin="2">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="10"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="10"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="42"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Row="0"
                                               Grid.Column="0"
                                               Text="字号"
                                               Style="{StaticResource ReadingPanelLabelStyle}"/>
                                    <StackPanel Grid.Row="0"
                                                Grid.Column="1"
                                                Orientation="Horizontal">
                                        <Button Content="A-"
                                                Style="{StaticResource ReadingPanelButtonStyle}"
                                                Command="{Binding DecreaseFontCommand}"
                                                Margin="0,0,8,0"
                                                ToolTip="字号减小"/>
                                        <Button Content="A+"
                                                Style="{StaticResource ReadingPanelButtonStyle}"
                                                Command="{Binding IncreaseFontCommand}"
                                                ToolTip="字号增大"/>
                                    </StackPanel>

                                    <TextBlock Grid.Row="2"
                                               Grid.Column="0"
                                               Text="行距"
                                               Style="{StaticResource ReadingPanelLabelStyle}"/>
                                    <StackPanel Grid.Row="2"
                                                Grid.Column="1"
                                                Orientation="Horizontal">
                                        <RadioButton Content="紧凑"
                                                     Style="{StaticResource ReadingPanelRadioStyle}"
                                                     Command="{Binding UseCompactLineHeightCommand}"
                                                     IsChecked="{Binding IsCompactLineHeightSelected, Mode=OneWay}"
                                                     GroupName="LineHeight"
                                                     Margin="0,0,6,0"/>
                                        <RadioButton Content="标准"
                                                     Style="{StaticResource ReadingPanelRadioStyle}"
                                                     Command="{Binding UseStandardLineHeightCommand}"
                                                     IsChecked="{Binding IsStandardLineHeightSelected, Mode=OneWay}"
                                                     GroupName="LineHeight"
                                                     Margin="0,0,6,0"/>
                                        <RadioButton Content="宽松"
                                                     Style="{StaticResource ReadingPanelRadioStyle}"
                                                     Command="{Binding UseRelaxedLineHeightCommand}"
                                                     IsChecked="{Binding IsRelaxedLineHeightSelected, Mode=OneWay}"
                                                     GroupName="LineHeight"/>
                                    </StackPanel>

                                    <TextBlock Grid.Row="4"
                                               Grid.Column="0"
                                               Text="布局"
                                               Style="{StaticResource ReadingPanelLabelStyle}"/>
                                    <Button Grid.Row="4"
                                            Grid.Column="1"
                                            Content="重置布局"
                                            Style="{StaticResource ReadingPanelButtonStyle}"
                                            Command="{Binding ResetLayoutCommand}"
                                            HorizontalAlignment="Left"
                                            MinWidth="84"/>
                                </Grid>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                </StackPanel>

                <TextBlock Grid.Column="1"
                           Text="{Binding CurrentFileName}"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"
                           Margin="16,0"
                           FontSize="13"
                           TextTrimming="CharacterEllipsis"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="打印" Command="{Binding PrintCommand}" Margin="0,0,8,0" MinWidth="66"/>
                    <Button Content="导出 PDF" Command="{Binding ExportPdfCommand}" Margin="0,0,8,0" MinWidth="86"/>
                    <Button x:Name="MoreMenuButton"
                            Content="更多"
                            Click="OpenButtonContextMenu"
                            MinWidth="66">
                        <Button.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="{Binding TranslateButtonText}"
                                          Command="{Binding TranslateCommand}"/>
                                <MenuItem Header="{Binding BilingualButtonText}"
                                          Command="{Binding BilingualCommand}"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Background="{DynamicResource AppBackgroundBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" MinWidth="210"/>
                <ColumnDefinition Width="1"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <ContentControl Grid.Column="0"
                            prism:RegionManager.RegionName="SidebarRegion"/>

            <GridSplitter Grid.Column="1"
                          Width="1"
                          HorizontalAlignment="Stretch"
                          Background="{DynamicResource BorderBrushSoft}"
                          ShowsPreview="True"/>

            <Border Grid.Column="2"
                    Background="{DynamicResource ContentBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrushSoft}"
                    BorderThickness="1,0,0,0">
                <ContentControl prism:RegionManager.RegionName="ContentRegion"/>
            </Border>
        </Grid>
    </DockPanel>
</Window>

